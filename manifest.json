{
  "manifest_version": 3,
  "name": "Platzen",
  "version": "1.3.0",
  "description": "Modo enfoque para Platzi: oculta el sidebar de comentarios y expande el video. Toggle desde popup, atajo o botón flotante.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://platzi.com/*", "*://*.platzi.com/*"],
      "css": ["hide-comments.css"],
      "js": ["icons.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Platzen",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-hide": {
      "suggested_key": {
        "default": "Alt+Shift+H",
        "mac": "Alt+Shift+H"
      },
      "description": "Mostrar u ocultar el sidebar de comentarios"
    }
  }
}
